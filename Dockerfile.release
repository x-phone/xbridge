FROM ubuntu:24.04

ARG TARGETARCH

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY docker-bin/linux-${TARGETARCH}/xbridge /usr/local/bin/xbridge

EXPOSE 8080
EXPOSE 10000-20000/udp

ENTRYPOINT ["xbridge"]
CMD ["--config", "/etc/xbridge/config.yaml"]
